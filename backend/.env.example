# ===========================================
# Backend Environment Variables
# ===========================================
# Copy this file to .env (dev) or set in docker-compose
# NEVER commit actual values to the repository

# Ollama Configuration
# Local: http://localhost:11434
# Docker: http://ollama:11434
OLLAMA_HOST=http://localhost:11434

# LLM Model to use (must be pulled in Ollama first)
OLLAMA_MODEL=qwen2.5:0.5b


# Resend API Key for contact form emails
# Get yours at: https://resend.com/api-keys
RESEND_API_KEY=

# Email to receive contact form submissions
CONTACT_EMAIL=your-email@example.com

# Auth Configuration (OAuth2 Client Credentials Flow)
# Generate a secure random key for JWT signing (min 32 chars)
SECRET_KEY=your-super-secret-key-here-min-32-chars
CLIENT_ID=portfolio-client
CLIENT_SECRET=your-client-secret-here
