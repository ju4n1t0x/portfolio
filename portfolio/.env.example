# ===========================================
# Frontend Environment Variables
# ===========================================
# Copy this file to .env.local (dev) or .env.production (prod)
# NEVER commit actual values to the repository

# Backend API URL
# Local: http://localhost:8000
# Docker: http://backend:8000
# Production: https://your-api-domain.com
VITE_API_URL=

# Auth Configuration (OAuth2 Client Credentials)
# These must match the backend CLIENT_ID and CLIENT_SECRET
VITE_CLIENT_ID=portfolio-client
VITE_CLIENT_SECRET=your-client-secret-here
