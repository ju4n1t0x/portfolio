[
  {
    "id": "TC001",
    "title": "Send a message and observe a streaming AI reply progressing in the chat",
    "description": "Verifies a user can send a message and see an AI response appear progressively as a streaming reply.",
    "category": "AI Chat Streaming",
    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /"
      },
      {
        "type": "assertion",
        "description": "Verify element \"chat input\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Hello! Can you summarize what you do?\" into the chat input"
      },
      {
        "type": "action",
        "description": "Click on \"Send\""
      },
      {
        "type": "assertion",
        "description": "Verify text \"Hello! Can you summarize what you do?\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify element \"assistant reply (streaming)\" is visible"
      },
      {
        "type": "assertion",
        "description": "Verify element \"assistant reply\" shows additional text appearing progressively (stream continues)"
      }
    ]
  },
