    "priority": "High",
    "steps": [
      {
        "type": "action",
        "description": "Navigate to /"
      },
      {
        "type": "action",
        "description": "Click on \"Contact\" in the sidebar"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Name\" is visible"
      },
      {
        "type": "action",
        "description": "Type \"Alex Tester\" into the name field"
      },
      {
        "type": "action",
        "description": "Type \"alex.tester@example.com\" into the email field"
      },
      {
        "type": "action",
        "description": "Type \"Hello, I’d like to get in touch about a project.\" into the message field"
      },
      {
        "type": "action",
        "description": "Click the \"Submit\" button"
      },
      {
        "type": "assertion",
        "description": "Verify text \"Success\" is visible"
      }
    ]
  },
